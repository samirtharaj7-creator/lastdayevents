{
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/timeline",
      "destination": "/timeline.html"
    },
    {
      "source": "/articles",
      "destination": "/articles.html"
    },
    {
      "source": "/article",
      "destination": "/article.html"
    },
    {
      "source": "/three-angels",
      "destination": "/three-angels.html"
    },
    {
      "source": "/first-angel",
      "destination": "/first-angel.html"
    },
    {
      "source": "/second-angel",
      "destination": "/second-angel.html"
    },
    {
      "source": "/third-angel",
      "destination": "/third-angel.html"
    },
    {
      "source": "/final-warning",
      "destination": "/final-warning.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
